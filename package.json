{
  "name": "qona",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend",
    "e2e"
  ],
  "scripts": {
    "dev": "concurrently -n api,web \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:api": "npm run dev -w backend",
    "dev:web": "npm run dev -w frontend",
    "build": "npm run build -w shared && npm run build -w backend && npm run build -w frontend",
    "build:shared": "npm run build -w shared",
    "build:api": "npm run build -w backend",
    "build:web": "npm run build -w frontend",
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test -w backend",
    "test:web": "npm run test -w frontend",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@number-flow/react": "^0.6.1",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.42.2"
  }
}
