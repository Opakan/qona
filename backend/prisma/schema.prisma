generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id        String   @id @default(cuid())
  authId    String   @unique
  email     String   @unique
  name      String
  avatarUrl String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflows        Workflow[]
  conversations    Conversation[]
  exportHistory    ExportHistory[]
  internalGraphs   InternalGraph[]
  planningSessions WorkflowPlanningSession[]
  apiKeys          ApiKey[]
  subscriptions    Subscription[]
  invoices         Invoice[]
  workflowPatterns WorkflowPattern[]
  executionLogs    WorkflowExecutionLog[]
  workflowDrafts   WorkflowDraft[]

  @@map("users")
}

model Workflow {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   @default("")
  definition  Json
  status      WorkflowStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions      WorkflowVersion[]
  conversations Conversation[]
  exportHistory ExportHistory[]

  @@index([userId])
  @@index([status])
  @@index([updatedAt])
}

model WorkflowVersion {
  id         String   @id @default(cuid())
  workflowId String
  version    Int
  definition Json
  changelog  String   @default("")
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
  @@index([workflowId])
}

model Conversation {
  id         String   @id @default(cuid())
  userId     String
  workflowId String?
  title      String
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow Workflow?             @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  messages ConversationMessage[]

  @@index([userId])
  @@index([workflowId])
  @@index([status])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model ExportHistory {
  id           String   @id @default(cuid())
  userId       String
  workflowId   String
  platform     String
  format       String   @default("json")
  status       String   @default("SUCCESS")
  fileUrl      String?
  metadata     Json     @default("{}")
  exportedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workflowId])
  @@index([exportedAt])
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String
  price       Int
  currency    String   @default("NGN")
  interval    String   @default("month")
  exports     Int
  features    Json     @default("[]")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id             String   @id @default(cuid())
  userId         String
  planId         String
  provider       String
  providerRef    String   @unique
  status         String   @default("ACTIVE")
  currentPeriod  DateTime @default(now())
  expiresAt      DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan  @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([userId])
  @@index([status])
}

model Invoice {
  id          String   @id @default(cuid())
  userId      String
  subscriptionId String?
  provider    String
  providerRef String   @unique
  amount      Int
  currency    String   @default("NGN")
  status      String   @default("PENDING")
  paidAt      DateTime?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([status])
}

model ApiKey {
  id         String   @id @default(cuid())
  userId     String
  keyHash    String   @unique
  name       String
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model InternalGraph {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   @default("")
  version     Int      @default(1)
  nodes       Json
  edges       Json
  metadata    Json     @default("{}")
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  planningSessions     WorkflowPlanningSession[]

  @@index([userId])
  @@index([status])
  @@map("internal_graphs")
}

model WorkflowPlanningSession {
  id                String   @id @default(cuid())
  userId            String
  state             String   @default("collecting_intent")
  collectedAnswers  Json     @default("{}")
  missingFields     Json     @default("[]")
  extractedIntent   Json?
  workflowDraft     Json?
  internalGraphId   String?
  conversationId    String?
  stage             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  graph       InternalGraph? @relation(fields: [internalGraphId], references: [id])

  @@index([userId])
  @@index([state])
  @@map("workflow_planning_sessions")
}

model WorkflowPattern {
  id              String   @id @default(cuid())
  userId          String
  goal            String
  triggerType     String
  triggerLabel    String   @default("")
  actionTypes     Json     @default("[]")
  integrationTypes Json    @default("[]")
  graphSnapshot   Json
  confidence      Float    @default(0)
  success         Boolean  @default(false)
  usageCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  executionLogs    WorkflowExecutionLog[]
  successPatterns  WorkflowSuccessPattern[]

  @@index([userId])
  @@index([triggerType])
  @@index([success])
  @@index([createdAt])
  @@map("workflow_patterns")
}

model WorkflowExecutionLog {
  id             String   @id @default(cuid())
  userId         String
  patternId      String?
  status         String   @default("PENDING")
  errorMessage   String?
  durationMs     Int?
  metadata       Json     @default("{}")
  executedAt     DateTime @default(now())

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  pattern WorkflowPattern? @relation(fields: [patternId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([patternId])
  @@index([status])
  @@index([executedAt])
  @@map("workflow_execution_logs")
}

model WorkflowSuccessPattern {
  id              String   @id @default(cuid())
  patternId       String?
  triggerType     String
  actionTypes     Json     @default("[]")
  integrationTypes Json    @default("[]")
  successCount    Int      @default(1)
  avgConfidence   Float    @default(0)
  lastUsedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  pattern WorkflowPattern? @relation(fields: [patternId], references: [id], onDelete: SetNull)

  @@index([triggerType])
  @@index([successCount])
  @@index([lastUsedAt])
  @@map("workflow_success_patterns")
}

model WorkflowDraft {
  id            String   @id @default(cuid())
  userId        String
  goal          String
  requirements  Json     @default("{}")
  internalGraph Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("workflow_drafts")
}
